# ==============================================================================
#  DAT-TWS Network Simulation Parameter Configuration
# ==============================================================================

# ==========================================
# 1. Basic Topology Parameters
# ==========================================
# Total number of Issuer nodes participating in the simulation
NUM_ISSUERS=5

# Base listening port for the nodes (used to distinguish different Issuer services on a single machine)
BASE_PORT=8001


# ==========================================
# 2. Scenario 1: Delay and Jitter
# ==========================================
# Target restriction: Egress network delay for Issuers and the Verifier.
# Note: The 'delay' setting in 'tc netem' configures the ONE-WAY delay.
#       If set to 50ms, the Round-Trip Time (RTT) will be approximately 100ms.
NET_DELAY="50ms"       
NET_JITTER="0ms"        # Jitter range to simulate network instability


# ==========================================
# 3. Scenario 2: Bandwidth Limitation
# ==========================================
# Target restriction: Bandwidth when Issuers return signatures to the User,
#                     and when the Verifier receives/responds to the User.
#
# [CRITICAL PARAMETER CONSTRAINTS (Severely impacts connectivity)]:
# 1. NET_BURST MUST be greater than the MTU (approx. 1.5KB / 12kbit), 
#    otherwise large packets will be dropped immediately!
# 2. NET_LATENCY MUST be greater than the time required to drain the burst buffer 
#    (NET_BURST / NET_BANDWIDTH). Otherwise, the kernel will drop packets 
#    upon detecting queue buildup, resulting in "No route to host" or disconnections.
# ==========================================
NET_BANDWIDTH="128kbit" # Simulates a severely restricted network (approx. 16KB/s)
NET_BURST="64kbit"      # Token bucket size (approx. 8KB). Satisfies > MTU and handles burst traffic
NET_LATENCY="600ms"     # Queue wait time limit. Here, 64k/128k = 0.5s, so 600ms is safe


# ==========================================
# 4. Scenario 3: Packet Loss Rate
# ==========================================
# Target restriction: Simulates packet loss for Issuer signature data 
#                     and Verifier request/response data over the network.
NET_LOSS="10%"          # Packet loss percentage