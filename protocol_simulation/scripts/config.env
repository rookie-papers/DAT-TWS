# ==============================================================================
#  DAT-TWS Real-World Network Simulation Configuration
# ==============================================================================

# ==========================================
# 1. Basic Deployment Parameters
# ==========================================
# Total number of Issuer nodes deployed on the current host
NUM_ISSUERS=5

# ==========================================
# 2. Scenario 1: Delay and Jitter
# ==========================================
# Note: This delay is ADDED to your existing physical network latency.
# If your baseline ping to the remote server is 40ms, setting this to 50ms
# will result in a total one-way latency of ~90ms.
NET_DELAY="50ms"       
NET_JITTER="5ms"        # Adds slight jitter for more realistic simulation


# ==========================================
# 3. Scenario 2: Bandwidth Limitation
# ==========================================
# Physical Interface Rate Limiting (TBF - Token Bucket Filter)
# [CRITICAL CONSTRAINTS]: 
# 1. NET_BURST MUST be > MTU (approx. 1.5KB / 12kbit). Recommended: > 1/4 of bandwidth.
# 2. NET_LATENCY MUST be > (NET_BURST / NET_BANDWIDTH) to prevent excessive packet drop.
# ==========================================
NET_BANDWIDTH="128kbit" # Target bandwidth limit (approx. 16KB/s)
NET_BURST="64kbit"      # Token bucket size (absorbs burst traffic, must be > MTU)
NET_LATENCY="600ms"     # Max queue wait time (64k/128k = 500ms, 600ms is safe)


# ==========================================
# 4. Scenario 3: Packet Loss Rate
# ==========================================
# Simulates packet loss over unstable wireless links (e.g., UAV communications)
NET_LOSS="5%"           # Packet loss percentage (Avoid >10% to prevent SSH disconnections)